}

.clue-panel textarea {
    width: 100%;
    min-height: 90px;
    border-radius: 6px;
    border: 1px solid #333645;
    background: #111119;
    color: var(--text-main);
    padding: 8px;
    font-family: monospace;
    font-size: 13px;
    box-sizing: border-box;
}

.clue-panel .actions {
    margin-top: 10px;
}

.clue-panel button {
    background: var(--accent);
    color: #ffffff;
    border: none;
    border-radius: 4px;
    padding: 6px 12px;
    font-size: 13px;
    cursor: pointer;
    margin-right: 6px;
}

.clue-panel button.secondary {
    background: transparent;
    border: 1px solid #3a3a4a;
    color: var(--text-main);
}

.clue-panel button:hover {
    filter: brightness(1.05);
}

.clue-panel .output {
    margin-top: 12px;
    padding: 8px;
    background: #111119;
    border-radius: 6px;
    border: 1px solid #333645;
    font-family: monospace;
    font-size: 13px;
    white-space: pre-wrap;
}


###############################################
# RUST SECTION
###############################################
// rust: simple clue utilities library
// after extraction, save as clue_tools.rs and compile with `rustc clue_tools.rs`

fn reverse(s: &str) -> String {
    s.chars().rev().collect()
}

fn upper(s: &str) -> String {
    s.to_uppercase()
}

fn lower(s: &str) -> String {
    s.to_lowercase()
}

fn word_count(s: &str) -> usize {
    s.split_whitespace().count()
}

fn unique_chars(s: &str) -> usize {
    use std::collections::HashSet;
    let mut set = HashSet::new();
    for ch in s.chars() {
        set.insert(ch);
    }
    set.len()
}

fn stats(s: &str) -> (usize, usize, usize) {
    let len = s.len();
    let words = word_count(s);
    let uniq = unique_chars(s);
    (len, words, uniq)
}

fn mask_vowels(s: &str, mask: char) -> String {
    let vowels = "aeiouAEIOU";
    s.chars()
        .map(|c| if vowels.contains(c) { mask } else { c })
        .collect()
}

fn preview(s: &str) -> String {
    let (len, words, uniq) = stats(s);
    format!("clue: {} | len={} words={} unique={}", s, len, words, uniq)
}

fn main() {
    let sample = "example clue for rust";
    println!("rust reverse: {}", reverse(sample));
    println!("rust upper: {}", upper(sample));
    println!("rust lower: {}", lower(sample));
    println!("rust mask vowels: {}", mask_vowels(sample, '*'));
    let (len, words, uniq) = stats(sample);
    println!("rust stats: len={} words={} unique={}", len, words, uniq);
    println!("rust preview: {}", preview(sample));
}


###############################################
# FORTRAN SECTION (for fun, a bit more)
###############################################
C fortran: simple clue utilities
C after extraction, save as clue_tools.f90 and compile with:
C   gfortran clue_tools.f90 -o clue_tools

      PROGRAM CLUE_MAIN
      IMPLICIT NONE
      CHARACTER(LEN=80) :: CLUE
      INTEGER :: L, W, I
      CHARACTER(LEN=1) :: C
      LOGICAL :: INWORD

      CLUE = "example clue for fortran utilities"
      CALL CLUE_STATS(CLUE, L, W)
      PRINT *, "fortran clue: ", TRIM(CLUE)
      PRINT *, "length:", L, "words:", W

      PRINT *, "masked vowels:"
      CALL MASK_VOWELS(CLUE)

      PRINT *, "uppercase:"
      CALL TO_UPPER(CLUE)

      PRINT *, "character codes:"
      DO I = 1, LEN_TRIM(CLUE)
         C = CLUE(I:I)
         PRINT *, I, C, ICHAR(C)
      END DO

      END PROGRAM CLUE_MAIN


      SUBROUTINE CLUE_STATS(TEXT, LENGTH, WORDS)
      IMPLICIT NONE
      CHARACTER(LEN=*), INTENT(IN) :: TEXT
      INTEGER, INTENT(OUT) :: LENGTH, WORDS
      INTEGER :: I, N
      CHARACTER(LEN=1) :: C
      LOGICAL :: INWORD

      N = LEN_TRIM(TEXT)
      LENGTH = N
      WORDS = 0
      INWORD = .FALSE.

      DO I = 1, N
         C = TEXT(I:I)
         IF (C .EQ. ' ') THEN
            IF (INWORD) THEN
               INWORD = .FALSE.
            END IF
         ELSE
            IF (.NOT. INWORD) THEN
               WORDS = WORDS + 1
               INWORD = .TRUE.
            END IF
         END IF
      END DO

      END SUBROUTINE CLUE_STATS


      SUBROUTINE MASK_VOWELS(TEXT)
      IMPLICIT NONE
      CHARACTER(LEN=*), INTENT(IN) :: TEXT
      INTEGER :: I, N
      CHARACTER(LEN=1) :: C

      N = LEN_TRIM(TEXT)
      DO I = 1, N
         C = TEXT(I:I)
         IF (C .EQ. 'A' .OR. C .EQ. 'E' .OR. C .EQ. 'I' .OR.
     &       C .EQ. 'O' .OR. C .EQ. 'U' .OR.
     &       C .EQ. 'a' .OR. C .EQ. 'e' .OR. C .EQ. 'i' .OR.
     &       C .EQ. 'o' .OR. C .EQ. 'u') THEN
            WRITE(*,'(A)', ADVANCE='NO') '*'
         ELSE
            WRITE(*,'(A)', ADVANCE='NO') C
         END IF
      END DO
      WRITE(*,*)
      END SUBROUTINE MASK_VOWELS


      SUBROUTINE TO_UPPER(TEXT)
      IMPLICIT NONE
      CHARACTER(LEN=*), INTENT(IN) :: TEXT
      INTEGER :: I, N
      CHARACTER(LEN=1) :: C

      N = LEN_TRIM(TEXT)
      DO I = 1, N
         C = TEXT(I:I)
         IF (C .GE. 'a' .AND. C .LE. 'z') THEN
            C = CHAR(ICHAR(C) - 32)
         END IF
         WRITE(*,'(A)', ADVANCE='NO') C
      END DO
      WRITE(*,*)
      END SUBROUTINE TO_UPPER
