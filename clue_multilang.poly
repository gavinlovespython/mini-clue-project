<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>clue preview ui</title>
    <style>
        body {
            font-family: system-ui, sans-serif;
            background: #f5f5f5;
            margin: 0;
            padding: 20px;
        }
        .container {
            max-width: 640px;
            margin: 0 auto;
            background: #ffffff;
            border-radius: 8px;
            padding: 16px 20px 24px;
            box-shadow: 0 2px 6px rgba(0,0,0,0.08);
        }
        h1 {
            font-size: 20px;
            margin-bottom: 12px;
        }
        textarea {
            width: 100%;
            min-height: 80px;
            padding: 8px;
            font-family: monospace;
            font-size: 14px;
            border-radius: 4px;
            border: 1px solid #ccc;
            box-sizing: border-box;
        }
        button {
            margin-top: 8px;
            margin-right: 6px;
            padding: 6px 10px;
            font-size: 13px;
            border-radius: 4px;
            border: 1px solid #888;
            background: #fafafa;
            cursor: pointer;
        }
        button:hover {
            background: #f0f0f0;
        }
        .output {
            margin-top: 12px;
            padding: 8px;
            background: #f9f9f9;
            border-radius: 4px;
            font-family: monospace;
            font-size: 13px;
            border: 1px solid #ddd;
            white-space: pre-wrap;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>clue preview</h1>
        <textarea id="clueInput">example clue from html ui</textarea>
        <div>
            <button onclick="doReverse()">reverse</button>
            <button onclick="doUpper()">upper</button>
            <button onclick="doStats()">stats</button>
        </div>
        <div id="output" class="output"></div>
    </div>
    <script>
        function getText() {
            return document.getElementById("clueInput").value;
        }
        function setOutput(text) {
            document.getElementById("output").textContent = text;
        }
        function doReverse() {
            const t = getText();
            setOutput(t.split("").reverse().join(""));
        }
        function doUpper() {
            const t = getText();
            setOutput(t.toUpperCase());
        }
        function doStats() {
            const t = getText();
            const words = t.trim().split(/\s+/).filter(Boolean);
            const stats = {
                length: t.length,
                words: words.length
            };
            setOutput("length=" + stats.length + " words=" + stats.words);
        }
    </script>
</body>
</html>


