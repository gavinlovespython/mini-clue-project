# ============================
# PYTHON MODULE: clue_tools.py
# Updated + expanded utilities
# ============================

import random
import string
from typing import Dict, List


def _normalize(text: str) -> str:
    """
    Internal helper to normalize whitespace and strip leading/trailing spaces.
    """
    return " ".join(text.strip().split())


def reverse_clue(text: str) -> str:
    """
    Return the clue reversed.
    """
    cleaned = _normalize(text)
    return cleaned[::-1]


def shuffle_clue(text: str) -> str:
    """
    Shuffle characters in a clue using a secure random shuffle.
    """
    cleaned = _normalize(text)
    chars = list(cleaned)
    random.SystemRandom().shuffle(chars)
    return "".join(chars)


def clue_stats(text: str) -> Dict[str, int]:
    """
    Return simple statistics about a clue.
    """
    cleaned = _normalize(text)
    return {
        "length": len(cleaned),
        "words": len(cleaned.split()),
        "unique_chars": len(set(cleaned)),
        "punctuation_count": sum(1 for c in cleaned if c in string.punctuation),
    }


def emphasize_clue(text: str) -> str:
    """
    Add a simple emphasis transformation:
    - Capitalize each word
    - Surround with decorative markers
    """
    cleaned = _normalize(text)
    emphasized = " ".join(word.capitalize() for word in cleaned.split())
    return f"★ {emphasized} ★"


def batch_process(clues: List[str]) -> List[Dict[str, str]]:
    """
    Process a list of clues and return a structured summary for each.
    """
    results = []
    for clue in clues:
        cleaned = _normalize(clue)
        results.append({
            "original": cleaned,
            "reversed": reverse_clue(cleaned),
            "shuffled": shuffle_clue(cleaned),
            "emphasized": emphasize_clue(cleaned),
        })
    return results


if __name__ == "__main__":
    sample = "example clue for testing"
    print("reverse:", reverse_clue(sample))
    print("shuffle:", shuffle_clue(sample))
    print("stats:", clue_stats(sample))
    print("emphasize:", emphasize_clue(sample))
    print("batch:", batch_process([sample, "another clue"]))

###############################################
# JAVASCRIPT SECTION
###############################################
/*
javascript: clue utilities for formatting and randomization
run with: node clue_multilang.poly (after extraction)
*/

function jsReverse(text) {
    return text.split("").reverse().join("");
}

function jsUpper(text) {
    return text.toUpperCase();
}

function jsLower(text) {
    return text.toLowerCase();
}

function jsShuffle(text) {
    return text
        .split("")
        .sort(() => Math.random() - 0.5)
        .join("");
}

function jsMaskVowels(text, mask = "*") {
    return text.replace(/[aeiouAEIOU]/g, mask);
}

function jsStats(text) {
    const words = text.trim().split(/\s+/).filter(Boolean);
    const length = text.length;
    const wordCount = words.length;
    const avgWordLength =
        wordCount === 0
            ? 0
            : words.reduce((sum, w) => sum + w.length, 0) / wordCount;
    const uniqueChars = new Set(text.split("")).size;
    return { length, wordCount, avgWordLength, uniqueChars };
}

function jsPreview(text) {
    const stats = jsStats(text);
    return `clue: ${text} | length=${stats.length} words=${stats.wordCount}`;
}

const jsSample = "example clue for javascript";
console.log("js reverse:", jsReverse(jsSample));
console.log("js upper:", jsUpper(jsSample));
console.log("js shuffle:", jsShuffle(jsSample));
console.log("js masked:", jsMaskVowels(jsSample));
console.log("js stats:", jsStats(jsSample));
console.log("js preview:", jsPreview(jsSample));


