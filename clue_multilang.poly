/* ============================
   HTML SECTION: demo.html
   ============================ */
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>clue picker demo</title>
  <link rel="stylesheet" href="demo.css">
</head>

<body>
  <header class="header">
    <p class="update-note">This is a small update for the demo branch.</p>
    <h1>clue picker demo</h1>
    <hr class="accent-line">
    <p class="subtitle">simple demo interface.</p>
  </header>

  <main class="container">
    <button id="pick" class="btn" title="pick a clue" aria-label="Pick a random clue">
      pick a clue
    </button>

    <p class="hint">press the button to generate a clue.</p>

    <div id="result" class="result-box" aria-live="polite"></div>
  </main>

  <script src="engine.js"></script>
</body>
</html>


/* ============================
   CSS SECTION: demo.css
   ============================ */
:root {
  --bg: #0f172a;
  --fg: #e5e7eb;
  --accent: #38bdf8;
  --accent-soft: rgba(56, 189, 248, 0.2);
  --border-soft: rgba(148, 163, 184, 0.4);
  --btn-bg: #1d4ed8;
  --btn-bg-hover: #2563eb;
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  min-height: 100vh;
  font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  background: radial-gradient(circle at top, #1e293b 0, #020617 55%);
  color: var(--fg);
  display: flex;
  align-items: center;
  justify-content: center;
}

.header {
  text-align: center;
  margin-bottom: 1.5rem;
}

.update-note {
  font-size: 0.85rem;
  color: #9ca3af;
  margin-bottom: 0.5rem;
}

.container {
  background: rgba(15, 23, 42, 0.9);
  border: 1px solid var(--border-soft);
  border-radius: 0.75rem;
  padding: 1.75rem 2rem 2rem;
  max-width: 420px;
  width: 100%;
  box-shadow: 0 18px 45px rgba(15, 23, 42, 0.9);
}

h1 {
  margin: 0.25rem 0;
  font-size: 1.4rem;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

.accent-line {
  border: none;
  height: 2px;
  margin: 0.75rem auto 0.75rem;
  width: 60%;
  background: linear-gradient(90deg, transparent, var(--accent), transparent);
}

.subtitle {
  margin: 0;
  font-size: 0.9rem;
  color: #9ca3af;
}

.btn {
  display: inline-block;
  margin-top: 1rem;
  padding: 0.6rem 1.4rem;
  border-radius: 999px;
  border: none;
  background: var(--btn-bg);
  color: #e5e7eb;
  font-weight: 600;
  font-size: 0.95rem;
  cursor: pointer;
  box-shadow: 0 10px 25px rgba(37, 99, 235, 0.45);
  transition: background 0.15s ease, transform 0.1s ease, box-shadow 0.15s ease;
}

.btn:hover {
  background: var(--btn-bg-hover);
  transform: translateY(-1px);
  box-shadow: 0 14px 30px rgba(37, 99, 235, 0.55);
}

.btn:active {
  transform: translateY(0);
  box-shadow: 0 8px 18px rgba(37, 99, 235, 0.4);
}

.hint {
  margin-top: 0.75rem;
  font-size: 0.85rem;
  color: #9ca3af;
}

.result-box {
  margin-top: 1.25rem;
  min-height: 2.4rem;
  padding: 0.75rem 0.9rem;
  border-radius: 0.6rem;
  border: 1px solid var(--border-soft);
  background: var(--accent-soft);
  font-size: 0.95rem;
  color: #e5e7eb;
  display: flex;
  align-items: center;
}


/* ============================
   JAVASCRIPT SECTION: engine.js
   ============================ */
export function pickClue(clues, options = {}) {
    // small helper: normalize whitespace
    const safeTrim = (str) => str.replace(/\s+/g, " ").trim();

    // small helper: detect suspicious punctuation patterns
    const isSuspicious = (str) => /(\?{3,}|!{3,})/.test(str);

    // config with optional features
    const config = {
        logging: options.logging || false,
        seed: options.seed || null,
        ultraRareChance: 0.01,
        rareChance: 0.05,
        maxLength: 120
    };

    // optional seeded RNG
    let rng = Math.random;
    if (config.seed !== null) {
        let s = config.seed % 2147483647;
        if (s <= 0) s += 2147483646;
        rng = () => (s = s * 16807 % 2147483647) / 2147483647;
    }

    const log = (...msg) => {
        if (config.logging) console.log("[engine]", ...msg);
    };

    // safety: missing list
    if (!clues || clues.length === 0) {
        log("no clues provided");
        return "no clues available";
    }

    // sanitize + trim
    clues = clues.map(c => safeTrim(c));

    // remove empty
    clues = clues.filter(c => c !== "");

    // remove duplicates
    clues = [...new Set(clues)];

    // length rule
    clues = clues.filter(c => c.length <= config.maxLength);

    // if everything got filtered out
    if (clues.length === 0) {
        log("all clues filtered out");
        return "no valid clues";
    }

    // rarity roll
    const roll = rng();
    log("rarity roll:", roll.toFixed(4));

    if (roll < config.ultraRareChance) {
        log("ultra rare triggered");
        return "💎 ultra‑rare clue discovered";
    }

    if (roll < config.rareChance) {
        log("rare triggered");
        return "✨ rare clue found";
    }

    // weighted scoring system
    const scored = clues.map(c => {
        let weight = 1;

        // keyword boosts
        const lower = c.toLowerCase();
        if (lower.includes("secret")) weight += 2;
        if (lower.includes("warning")) weight += 1;

        // short clues get a tiny boost
        if (c.length < 40) weight += 0.5;

        // suspicious punctuation gets a tiny penalty
        if (isSuspicious(c)) {
            weight -= 0.25;
            log("suspicious punctuation detected:", c);
        }

        return { text: c, weight };
    });

    // compute total weight
    const totalWeight = scored.reduce((sum, item) => sum + item.weight, 0);

    // weighted pick
    let pick = rng() * totalWeight;

    for (const item of scored) {
        if (pick < item.weight) {
            log("picked:", item.text);
            return item.text;
        }
        pick -= item.weight;
    }

    // fallback (should never hit)
    log("fallback triggered");
    return clues[0];
}

// simple browser wiring example
document.addEventListener("DOMContentLoaded", () => {
    const button = document.getElementById("pick");
    const resultBox = document.getElementById("result");

    if (!button || !resultBox) return;

    const demoClues = [
        "secret path behind the waterfall",
        "warning: the door locks automatically",
        "look up at the third window",
        "follow the blue markings on the floor",
        "the key is under the loose tile"
    ];

    button.addEventListener("click", () => {
        const clue = pickClue(demoClues, { logging: false });
        resultBox.textContent = clue || "No clue available — try again!";
    });
});


# ============================
# PYTHON SECTION: clue_tools.py
# ============================
import random
import string
from typing import Dict, List


def _normalize(text: str) -> str:
    """
    Internal helper to normalize whitespace and strip leading/trailing spaces.
    """
    return " ".join(text.strip().split())


def reverse_clue(text: str) -> str:
    """
    Return the clue reversed.
    """
    cleaned = _normalize(text)
    return cleaned[::-1]


def shuffle_clue(text: str) -> str:
    """
    Shuffle characters in a clue using a secure random shuffle.
    """
    cleaned = _normalize(text)
    chars = list(cleaned)
    random.SystemRandom().shuffle(chars)
    return "".join(chars)


def clue_stats(text: str) -> Dict[str, int]:
    """
    Return simple statistics about a clue.
    """
    cleaned = _normalize(text)
    return {
        "length": len(cleaned),
        "words": len(cleaned.split()),
        "unique_chars": len(set(cleaned)),
        "punctuation_count": sum(1 for c in cleaned if c in string.punctuation),
    }


def emphasize_clue(text: str) -> str:
    """
    Add a simple emphasis transformation:
    - Capitalize each word
    - Surround with decorative markers
    """
    cleaned = _normalize(text)
    emphasized = " ".join(word.capitalize() for word in cleaned.split())
    return f"★ {emphasized} ★"


def batch_process(clues: List[str]) -> List[Dict[str, str]]:
    """
    Process a list of clues and return a structured summary for each.
    """
    results = []
    for clue in clues:
        cleaned = _normalize(clue)
        results.append({
            "original": cleaned,
            "reversed": reverse_clue(cleaned),
            "shuffled": shuffle_clue(cleaned),
            "emphasized": emphasize_clue(cleaned),
        })
    return results


if __name__ == "__main__":
    sample = "example clue for testing"
    print("reverse:", reverse_clue(sample))
    print("shuffle:", shuffle_clue(sample))
    print("stats:", clue_stats(sample))
    print("emphasize:", emphasize_clue(sample))
    print("batch:", batch_process([sample, "another clue"]))


// ============================
// RUST SECTION: demo.rs
// ============================
use rand::seq::SliceRandom;
use rand::thread_rng;

// load all clues
fn load_clues() -> Vec<&'static str> {
    vec![
        "the sky is blue",
        "rust is fast",
        "python is friendly",
        "clues are fun",
        "coding builds skill",
    ]
}

// pick a single random clue
fn pick_random_clue(clues: &[&str]) -> Option<&str> {
    let mut rng = thread_rng();
    clues.choose(&mut rng).copied()
}

// preview 3 random clues
fn preview_random_clues(clues: &[&str]) {
    let mut rng = thread_rng();
    println!("\n--- previewing 3 random clues ---");
    for c in clues.choose_multiple(&mut rng, 3) {
        println!("• {}", c);
    }
}

// show total count
fn show_total(clues: &[&str]) {
    println!("\ntotal clues available: {}", clues.len());
}

// print menu
fn show_menu() {
    println!("\n=== rust demo menu ===");
    println!("1. pick a clue");
    println!("2. preview 3 random clues");
    println!("3. exit");
    println!("4. show total clues");
    println!("======================");
}

// read user input trimmed
fn read_choice() -> String {
    let mut input = String::new();
    std::io::stdin().read_line(&mut input).unwrap();
    input.trim().to_string()
}

fn main() {
    let clues = load_clues();

    loop {
        show_menu();
        let choice = read_choice();

        match choice.as_str() {
            "1" => {
                match pick_random_clue(&clues) {
                    Some(c) => println!("\npicked clue: {}", c),
                    None => println!("\nno clues available"),
                }
            }
            "2" => preview_random_clues(&clues),
            "3" => {
                println!("goodbye!");
                break;
            }
            "4" => show_total(&clues),
            _ => println!("invalid choice"),
        }
    }
}


! ============================
! FORTRAN SECTION: clue_demo.f90
! ============================
program clue_demo
  implicit none
  character(len=*), parameter :: clues(3) = [ &
       "fortran still lives", &
       "clues can be classic", &
       "arrays start at one" ]

  integer :: i

  print *, "Fortran clue demo:"
  do i = 1, size(clues)
     print *, " - ", trim(clues(i))
  end do
end program clue_demo
