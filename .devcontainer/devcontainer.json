// Dev container configuration for the clue-system project
{
  "name": "clue-system",
  "image": "mcr.microsoft.com/devcontainers/base:latest",

  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.11"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "18"
    }
  },

  "customizations": {
    "vscode": {
      "settings": {
        "python.formatting.provider": "black",
        "editor.formatOnSave": true
      },
      "extensions": [
        "ms-python.python",
        "ms-python.black-formatter",
        "esbenp.prettier-vscode"
      ]
    }
  },

  "postCreateCommand": "pip install -r requirements.txt 2>/dev/null || true && npm install 2>/dev/null || true && echo 'devcontainer ready'"
}
