 // Dev container configuration for the clue-system project
{
  "name": "clue-system",
  "image": "mcr.microsoft.com/devcontainers/base:latest",

  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.11"
    }
  },

  "customizations": {
    "vscode": {
      "settings": {
        "python.formatting.provider": "black",
        "editor.formatOnSave": true
      },
      "extensions": [
        "ms-python.python",
        "ms-python.black-formatter"
      ]
    }
  },

  "postCreateCommand": "pip install -r requirements.txt && echo 'devcontainer ready'"
}
